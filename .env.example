# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el .env real a git

# Base de datos
POSTGRES_USER=saaspos_user
POSTGRES_PASSWORD=cambiar_por_password_seguro

# JWT - debe ser una cadena aleatoria de al menos 32 caracteres
JWT_SECRET=cambiar_por_secreto_muy_largo_y_aleatorio_minimo_32_chars

# URLs - reemplazar con tu dominio real o IP del servidor
FRONTEND_URL=https://tu-dominio.com
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com
